<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="using:System">

  <!--
    Шрифтовые стеки MarkMello.

    Источник истины: MarkMelloDesign/src/styles.css

      Document (serif):  Source Serif 4, Source Serif Pro, Iowan Old Style, Georgia, serif
      UI/document sans:  Inter Tight, Segoe UI Variable, Segoe UI, system-ui, sans-serif
      Mono:              JetBrains Mono, Consolas, monospace

    Дизайн-шрифты идут первыми. Если они установлены в системе, они и будут
    использованы. Если нет, работает системный fallback.

    Встраивание .ttf через AvaloniaResource — отдельная задача
    (licensing review + package size impact), в этой итерации не делается.
  -->

  <FontFamily x:Key="MmDocumentSerifFontFamily">Source Serif 4, Source Serif Pro, Iowan Old Style, Georgia, Cambria, serif</FontFamily>
  <FontFamily x:Key="MmDocumentSansFontFamily">Inter Tight, Segoe UI Variable, Segoe UI, Inter, system-ui, sans-serif</FontFamily>
  <FontFamily x:Key="MmDocumentMonoFontFamily">JetBrains Mono, Cascadia Code, Consolas, Menlo, monospace</FontFamily>

  <sys:Double x:Key="MmDocumentFontSize">18</sys:Double>
  <sys:Double x:Key="MmDocumentLineHeight">1.7</sys:Double>
  <sys:Double x:Key="MmDocumentMaxWidth">720</sys:Double>

  <sys:Double x:Key="MmTitleBarHeight">36</sys:Double>

</ResourceDictionary>
