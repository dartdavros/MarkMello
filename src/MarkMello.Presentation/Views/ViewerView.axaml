<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MarkMello.Presentation.ViewModels"
             xmlns:views="using:MarkMello.Presentation.Views"
             mc:Ignorable="d"
             x:Class="MarkMello.Presentation.Views.ViewerView"
             x:DataType="vm:MainWindowViewModel">

  <ScrollViewer Name="DocScroll"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto"
                UseLayoutRounding="True">
    <Grid UseLayoutRounding="True">
      <Border MaxWidth="{Binding ReadingPreferences.ContentWidth}"
              HorizontalAlignment="Center"
              Padding="72,96,72,160"
              UseLayoutRounding="True">
        <views:MarkdownDocumentView Document="{Binding RenderedDocument}"
                                    ReadingPreferences="{Binding ReadingPreferences}"
                                    UseLayoutRounding="True" />
      </Border>
    </Grid>
  </ScrollViewer>

</UserControl>
