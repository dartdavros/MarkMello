<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:MarkMello.Presentation.ViewModels"
        xmlns:views="using:MarkMello.Presentation.Views"
        mc:Ignorable="d"
        x:Class="MarkMello.Presentation.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280" Height="840"
        MinWidth="640" MinHeight="480"
        Title="{Binding WindowTitle}"
        Background="{DynamicResource MmBackgroundBrush}"
        DragDrop.AllowDrop="True">

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}" />
    <KeyBinding Gesture="Cmd+O" Command="{Binding OpenFileCommand}" />
    <KeyBinding Gesture="F5" Command="{Binding ReloadCommand}" />
    <KeyBinding Gesture="Ctrl+R" Command="{Binding ReloadCommand}" />
    <KeyBinding Gesture="Cmd+R" Command="{Binding ReloadCommand}" />
    <KeyBinding Gesture="Escape" Command="{Binding ClearErrorCommand}" />
  </Window.KeyBindings>

  <Window.Styles>
    <!-- Hover-reveal chrome via :pointerover on Window -->
    <Style Selector="Border.mm-top-chrome">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Window:pointerover Border.mm-top-chrome">
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Border.mm-status">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.20" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Window:pointerover Border.mm-status">
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="ProgressBar.mm-progress">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.24" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Window:pointerover ProgressBar.mm-progress">
      <Setter Property="Opacity" Value="0.6" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*">

    <!-- ===== Title bar ===== -->
    <Border Grid.Row="0"
            Height="36"
            Background="{DynamicResource MmTitleBarBrush}">
      <Grid ColumnDefinitions="*,Auto">

        <!-- Title text + full drag surface for the whole left caption area -->
        <Border Grid.Column="0"
                Background="Transparent"
                PointerPressed="OnTitleBarPointerPressed">
          <DockPanel LastChildFill="True"
                     Margin="14,0,0,0"
                     VerticalAlignment="Center">
            <Ellipse DockPanel.Dock="Left"
                     Width="5" Height="5"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"
                     Fill="{DynamicResource MmAccentBrush}"
                     IsVisible="{Binding IsViewer}" />
            <TextBlock Text="{Binding WindowTitle}"
                       FontSize="12"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Foreground="{DynamicResource MmTitleBarTextBrush}" />
          </DockPanel>
        </Border>

        <!-- Win-only window controls -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    IsVisible="{Binding ShowCustomTitleBar}">
          <Button Classes="titlebar"
                  Click="OnMinimizeClick"
                  ToolTip.Tip="Minimize">
            <Path Data="M0,5 L10,5"
                  Stroke="{DynamicResource MmTitleBarTextBrush}"
                  StrokeThickness="1" />
          </Button>
          <Button Classes="titlebar"
                  Click="OnMaximizeClick"
                  ToolTip.Tip="Maximize">
            <Path Data="M0,0 L10,0 L10,10 L0,10 Z"
                  Stroke="{DynamicResource MmTitleBarTextBrush}"
                  StrokeThickness="1"
                  Fill="Transparent" />
          </Button>
          <Button Classes="titlebar close"
                  Click="OnCloseClick"
                  ToolTip.Tip="Close">
            <Path Data="M0,0 L10,10 M10,0 L0,10"
                  Stroke="{DynamicResource MmTitleBarTextBrush}"
                  StrokeThickness="1" />
          </Button>
        </StackPanel>

      </Grid>
    </Border>

    <!-- ===== Body ===== -->
    <Panel Grid.Row="1">

      <!-- Content states -->
      <views:WelcomeView IsVisible="{Binding IsWelcome}" />
      <views:ViewerView IsVisible="{Binding IsViewer}" />
      <views:LoadErrorView IsVisible="{Binding IsError}" />

      <!-- Reading progress (top of body, hover-reveal) -->
      <ProgressBar Classes="mm-progress"
                   IsVisible="{Binding IsViewer}"
                   Value="{Binding ReadingProgress}"
                   Maximum="100"
                   Height="2"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Stretch"
                   Background="Transparent"
                   Foreground="{DynamicResource MmAccentBrush}" />

      <!-- Top bar (hover-reveal) -->
      <Border Classes="mm-top-chrome"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="0,12,16,0">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Button Classes="topbar-ghost"
                  Command="{Binding CycleThemeCommand}"
                  ToolTip.Tip="{Binding NextThemeHint}">
            <Grid Width="14" Height="14">
              <Path IsVisible="{Binding ShowsMoonThemeIcon}"
                    Data="M10.5 8.5A4 4 0 1 1 5.5 3.5 3.2 3.2 0 0 0 10.5 8.5Z"
                    Stroke="{DynamicResource MmTextSoftBrush}"
                    StrokeThickness="1.5"
                    StrokeJoin="Round"
                    StrokeLineCap="Round"
                    Fill="Transparent"
                    Stretch="Uniform" />
              <Canvas IsVisible="{Binding ShowsSunThemeIcon}"
                      Width="14"
                      Height="14">
                <Ellipse Canvas.Left="4.25"
                         Canvas.Top="4.25"
                         Width="5.5"
                         Height="5.5"
                         Stroke="{DynamicResource MmTextSoftBrush}"
                         StrokeThickness="1.5"
                         Fill="Transparent" />
                <Line StartPoint="7,0.75" EndPoint="7,2.1"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="7,11.9" EndPoint="7,13.25"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="0.75,7" EndPoint="2.1,7"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="11.9,7" EndPoint="13.25,7"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="2.15,2.15" EndPoint="3.1,3.1"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="10.9,10.9" EndPoint="11.85,11.85"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="2.15,11.85" EndPoint="3.1,10.9"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
                <Line StartPoint="10.9,3.1" EndPoint="11.85,2.15"
                      Stroke="{DynamicResource MmTextSoftBrush}"
                      StrokeThickness="1.5"
                      StrokeLineCap="Round" />
              </Canvas>
            </Grid>
          </Button>
        </StackPanel>
      </Border>

      <!-- Status bar (hover-reveal) -->
      <Border Classes="mm-status"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Bottom"
              Padding="20,0,20,14"
              IsHitTestVisible="False">
        <Grid ColumnDefinitions="*,Auto">

          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="18">
            <StackPanel Orientation="Horizontal" Spacing="6"
                        IsVisible="{Binding IsViewer}">
              <TextBlock Text="{Binding FileName}"
                         FontSize="11"
                         Foreground="{DynamicResource MmTextSoftBrush}" />
            </StackPanel>
            <TextBlock Text="{Binding WordCount, StringFormat='{}{0:N0} words'}"
                       FontSize="11"
                       Foreground="{DynamicResource MmTextFaintBrush}"
                       IsVisible="{Binding IsViewer}" />
            <TextBlock Text="{Binding ReadTimeMinutes, StringFormat='{}{0} min read'}"
                       FontSize="11"
                       Foreground="{DynamicResource MmTextFaintBrush}"
                       IsVisible="{Binding IsViewer}" />
          </StackPanel>

          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <Border Classes="kbd">
                <TextBlock Text="Ctrl" FontFamily="{DynamicResource MmDocumentMonoFontFamily}" FontSize="10" />
              </Border>
              <Border Classes="kbd">
                <TextBlock Text="O" FontFamily="{DynamicResource MmDocumentMonoFontFamily}" FontSize="10" />
              </Border>
              <TextBlock Text="open" FontSize="11" Foreground="{DynamicResource MmTextFaintBrush}" VerticalAlignment="Center" Margin="2,0,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding IsViewer}">
              <Border Classes="kbd">
                <TextBlock Text="F5" FontFamily="{DynamicResource MmDocumentMonoFontFamily}" FontSize="10" />
              </Border>
              <TextBlock Text="reload" FontSize="11" Foreground="{DynamicResource MmTextFaintBrush}" VerticalAlignment="Center" Margin="2,0,0,0" />
            </StackPanel>
          </StackPanel>

        </Grid>
      </Border>

      <!-- Drag overlay -->
      <Border IsVisible="{Binding IsDragHovering}"
              IsHitTestVisible="False"
              Background="{DynamicResource MmAccentSoftBrush}"
              BorderBrush="{DynamicResource MmAccentBrush}"
              BorderThickness="2"
              CornerRadius="10"
              Margin="12">
        <TextBlock Text="Drop your Markdown file to open"
                   FontFamily="{DynamicResource MmDocumentSansFontFamily}"
                   FontSize="14"
                   Foreground="{DynamicResource MmAccentBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
      </Border>

    </Panel>

  </Grid>

</Window>
